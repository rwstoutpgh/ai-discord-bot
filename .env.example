# Discord bot token (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your-bot-token-here

# Comma-separated Discord user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789012345678

# Working directory for AI agents (default: home directory)
WORKING_DIR=~

# Default backend: claude, codex, or mlx
DEFAULT_BACKEND=claude

# Default models (optional)
DEFAULT_CLAUDE_MODEL=sonnet
DEFAULT_CODEX_MODEL=codex
DEFAULT_MLX_MODEL=gemma4

# MLX server URL (only needed if using local models)
MLX_URL=http://localhost:8800

# Directory where project briefs and builds are stored
PROJECTS_DIR=~/projects
